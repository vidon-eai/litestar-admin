# ==================================
# Development Environment Configuration File
# ==================================

ENVIRONMENT=dev

# Server Configuration
SERVER_HOST=localhost
SERVER_PORT=8002

LITESTAR_HOST=0.0.0.0
LITESTAR_PORT=5000
LITESTAR_DEBUG=True

# Application Configuration
ROOT_PATH=/api/v1

# API Documentation Configuration
DEBUG=true
TITLE="🎉 Liststar Admin 🎉 -Development"
VERSION=0.1.0
SUMMARY=API Summary
DESCRIPTION=This is a web service framework based on python, based on Litestar and sqlalchemy implementation.

# Enable Demo Mode
DEMO_ENABLE=false

# Database Configuration
DATABASE_TYPE=mysql
DATABASE_HOST=localhost
DATABASE_PORT=3320
DATABASE_USERNAME=litestaradmin
DATABASE_PASSWORD=litestaradmin
DATABASE_NAME=litestaradmin

# Logging Configuration
LOGGER_LEVEL=DEBUG