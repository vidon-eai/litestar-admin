# ==================================
# Development Environment Configuration File
# ==================================

ENVIRONMENT=dev

# Server Configuration
SERVER_HOST=localhost
SERVER_PORT=8001

# Application Configuration
ROOT_PATH=/api/v1

# API Documentation Configuration
DEBUG=true
TITLE="🎉 Liststar Admin 🎉 -Development"
VERSION=0.1.0
SUMMARY=API Summary
DESCRIPTION=This is a web service framework based on python, based on Litestar and sqlalchemy implementation.

# Enable Demo Mode
DEMO_ENABLE=false

# Database Configuration
DATABASE_TYPE=mysql
DATABASE_HOST=localhost
DATABASE_PORT=3308
DATABASE_USER=root
DATABASE_PASSWORD=root_password
DATABASE_NAME=fastapiadmin

# Logging Configuration
LOGGER_LEVEL=DEBUG